# すべて任意。未設定でも RSS + 本文抽出 + CSS抽象サムネで動作します。
# 値を入れたら、このファイルを .env にコピーしてください: cp .env.example .env

# --- 画像（フリー素材API・無料登録）---
# Unsplash: https://unsplash.com/developers でアプリ登録 → Access Key
UNSPLASH_KEY=
# Pexels: https://www.pexels.com/api/ で API Key を取得
PEXELS_KEY=

# --- ニュース取得の補助ソース（任意）---
# NewsAPI: https://newsapi.org/  ※無料枠は localhost 限定・24h 遅延・本文は抜粋のみ
NEWSAPI_KEY=
# GNews: https://gnews.io/  ※無料枠 100req/日
GNEWS_KEY=
# Tavily 検索: https://tavily.com/  ※無料枠あり
TAVILY_KEY=
